<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- The above 3 meta tags *must* come first in the head; any other head content must come *after* these tags -->
    <title><%= current_page.data.title || "Christian Niles" %></title>
    <%= partial "layouts/stylesheet_tags" %>
  </head>

  <body class="full-article <%= page_classes %>">
    <%= partial "layouts/nav" %>
    <div class="container">
      <h2 class="article-header">
        <%= current_article.title %><br />
        <small><%= current_article.date.strftime('%b %e %Y') %></small>
      </h2>
      
      <%= yield %>
      <%= partial "layouts/footer" %>
    </div>
    
    <%= partial "layouts/script_tags" %>
  </body>
</html>
